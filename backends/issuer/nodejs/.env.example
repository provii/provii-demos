# Provii Issuer Backend Configuration
# Copy to .env and update with your credentials.
#
# Sandbox: mint per-developer credentials at https://playground.provii.app
# under the "Set up an Issuing Party" tab. The credential expires in 72 hours.
# Production: pull credentials from https://admin.provii.app.

# Issuing party client ID (cl_iss_sandbox_... in sandbox)
CLIENT_ID=cl_iss_sandbox_your_minted_id

# Base64url-encoded HMAC secret
HMAC_SECRET=your_minted_hmac_secret

# Issuer API base URL
# Sandbox: https://sandbox-issuer.provii.app
# Production: https://issuer.provii.app
ISSUER_API_URL=https://sandbox-issuer.provii.app

# Server port
PORT=3000

# CORS: comma-separated list of allowed origins
# Default: http://localhost:3000,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Set to 'production' to enable HSTS headers
NODE_ENV=development
