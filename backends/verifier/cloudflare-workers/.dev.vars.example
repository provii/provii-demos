# Provii Verifier Backend Configuration (Cloudflare Workers, local dev)
# Copy to .dev.vars (NOT .env). wrangler dev autoloads .dev.vars only.
# For deployed Workers, push secrets via `wrangler secret put`.
#
# Sandbox: mint per-developer credentials at https://playground.provii.app
# under the "Set up a Verifier" tab. The credential expires in 72 hours.
# Production: pull credentials from https://admin.provii.app.

# Your relying party client ID (rp_sandbox_... in sandbox, rp_... in production)
CLIENT_ID=rp_sandbox_your_minted_id

# Your relying party API key
API_KEY=your_minted_api_key

# Base64url-encoded HMAC secret
HMAC_SECRET=your_minted_hmac_secret

# Verifier API URL. wrangler.toml leaves this unset by default so the demo
# defers to the centralised playground config; uncomment to override locally.
#VERIFIER_API_URL=https://sandbox-verify.provii.app
