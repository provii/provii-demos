# Provii Verifier Backend Configuration (Go)
# Copy to .env and update with your minted credentials.
# main.go autoloads .env via github.com/joho/godotenv/autoload.
#
# Sandbox: mint per-developer credentials at https://playground.provii.app
# under the "Set up a Verifier" tab. The credential expires in 72 hours.
# Production: pull credentials from https://admin.provii.app.

# Verifier API URL (sandbox or production)
# Sandbox: https://sandbox-verify.provii.app
# Production: https://verify.provii.app
VERIFIER_API_URL=https://sandbox-verify.provii.app

# Your relying party client ID (rp_sandbox_... in sandbox, rp_... in production)
CLIENT_ID=rp_sandbox_your_minted_id

# Your relying party API key
API_KEY=your_minted_api_key

# Base64url-encoded HMAC secret
HMAC_SECRET=your_minted_hmac_secret

# Port for the backend server
PORT=3001

# Origin the backend sends to provii-verifier on outbound requests.
# Sandbox bypasses the allowlist; the playground value works there.
REGISTERED_ORIGIN=https://playground.provii.app

# Set to "production" to enable strict cookie + CORS rules in this demo.
GO_ENV=
