{
  "name": "provii-verifier-backend-demo",
  "version": "1.0.0",
  "description": "Demo backend showing how third-party verifiers (apps) integrate with Provii",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "generate-openapi": "tsx src/openapi.ts > openapi.json"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "dotenv": "^17.4.2",
    "hono": "^4.12.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@vitest/coverage-v8": "^4.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
