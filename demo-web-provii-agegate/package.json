{
  "name": "provii-demos",
  "version": "1.0.0",
  "description": "Reference implementation of Provii age verification with server-side proxying",
  "private": true,
  "scripts": {
    "regen:sdk-sri": "node scripts/regen-sdk-sri.mjs",
    "verify:sdk-sri": "node scripts/regen-sdk-sri.mjs --check",
    "prebuild": "npm run verify:sdk-sri",
    "build": "esbuild src/index.ts --bundle --format=esm --outfile=dist/index.js --external:__STATIC_CONTENT_MANIFEST",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "update-agegate": "cd ../provii-agegate && npm run build:demo && cp demo/agegate.* ../provii-demos/public/",
    "test-local": "npm run build && npm run dev",
    "lint": "eslint 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.3",
    "@cloudflare/workers-types": "^4.20260205.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.58.1",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5",
    "wrangler": "^4.62.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@cloudflare/kv-asset-handler": "^0.4.2",
    "@noble/hashes": "^2.2.0",
    "canonicalize": "3.0.0",
    "zod": "^4.3.6"
  }
}
